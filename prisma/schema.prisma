generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  plan           Plan      @default(FREE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  packageSubscriptions PackageSubscription[]
  alerts               Alert[]
  integrations         Integration[]
  savedSearches        SavedSearch[]
  githubRepositories   GitHubRepository[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PackageSubscription {
  id          String   @id @default(cuid())
  userId      String
  packageName String
  version     String?
  ecosystem   String   @default("npm")
  muted       Boolean  @default(false)
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts Alert[]

  @@unique([userId, packageName, ecosystem])
  @@index([packageName])
  @@map("package_subscriptions")
}

model Advisory {
  id               String   @id @default(cuid())
  externalId       String   @unique
  packageName      String
  ecosystem        String   @default("npm")
  title            String
  summary          String
  severity         Severity
  affectedVersions String
  patchedVersions  String?
  publishedAt      DateTime
  sourceUrl        String
  cvssScore        Float?
  cveId            String?
  createdAt        DateTime @default(now())

  alerts Alert[]

  @@index([packageName])
  @@index([severity])
  @@index([publishedAt])
  @@map("advisories")
}

model Alert {
  id                    String      @id @default(cuid())
  userId                String
  advisoryId            String
  packageSubscriptionId String?
  status                AlertStatus @default(NEW)
  sentSlack             Boolean     @default(false)
  sentEmail             Boolean     @default(false)
  sentTelegram          Boolean     @default(false)
  sentPagerDuty         Boolean     @default(false)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  advisory            Advisory             @relation(fields: [advisoryId], references: [id], onDelete: Cascade)
  packageSubscription PackageSubscription? @relation(fields: [packageSubscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([createdAt])
  @@map("alerts")
}

model Integration {
  id         String          @id @default(cuid())
  userId     String
  type       IntegrationType
  config     Json
  enabled    Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("integrations")
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

model ScrapeSource {
  id            String       @id @default(cuid())
  name          String       @unique
  url           String
  enabled       Boolean      @default(true)
  intervalMs    Int          @default(300000) // 5 minutes
  lastScrapedAt DateTime?
  lastStatus    String?      // "success" | "error"
  lastError     String?
  itemsFound    Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  feedItems FeedItem[]

  @@map("scrape_sources")
}

model FeedItem {
  id           String   @id @default(cuid())
  sourceId     String
  externalId   String   @unique
  type         String   // maps to SignalType
  title        String
  description  String
  severity     Severity
  packageName  String?
  ecosystem    String?
  sourceUrl    String?
  metadata     Json?
  publishedAt  DateTime
  createdAt    DateTime @default(now())

  source ScrapeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([publishedAt])
  @@index([severity])
  @@index([packageName])
  @@map("feed_items")
}

model GitHubRepository {
  id              String    @id @default(cuid())
  userId          String
  owner           String
  name            String
  fullName        String
  defaultBranch   String    @default("main")
  language        String?
  private         Boolean   @default(false)
  vulnerabilities Int       @default(0)
  lastScanAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fullName])
  @@index([userId])
  @@map("github_repositories")
}

enum Plan {
  FREE
  INDIVIDUAL
  TEAM
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum AlertStatus {
  NEW
  ACKNOWLEDGED
  RESOLVED
  IGNORED
}

enum IntegrationType {
  SLACK
  PAGERDUTY
  TELEGRAM
  EMAIL
}
